{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/secmesh/report.schema.json",
  "title": "SecMesh Assessment Report (v1)",
  "type": "object",
  "required": [
    "schema_version",
    "report_id",
    "generated_at",
    "asset",
    "summary",
    "mapped_findings",
    "control_results",
    "recommendations"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "report_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "time_window": {
      "type": "object",
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "asset": {
      "type": "object",
      "required": [
        "org_id",
        "asset_id",
        "environment"
      ],
      "properties": {
        "org_id": {
          "type": "string"
        },
        "asset_id": {
          "type": "string"
        },
        "environment": {
          "type": "string",
          "enum": [
            "dev",
            "staging",
            "prod"
          ]
        },
        "name": {
          "type": [
            "string",
            "null"
          ]
        },
        "version": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "overall_risk_score",
        "findings_total",
        "controls_total"
      ],
      "properties": {
        "overall_risk_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "findings_total": {
          "type": "integer",
          "minimum": 0
        },
        "findings_by_severity": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "controls_total": {
          "type": "integer",
          "minimum": 0
        },
        "controls_by_status": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "top_techniques": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "mapped_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding",
          "techniques"
        ],
        "properties": {
          "finding": {
            "type": "object",
            "required": [
              "cve",
              "title",
              "exposure"
            ],
            "properties": {
              "cve": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "cwe": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "component": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "installed_version": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "fixed_version": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "cvss_v3": {
                "type": [
                  "number",
                  "null"
                ],
                "minimum": 0,
                "maximum": 10
              },
              "epss": {
                "type": [
                  "number",
                  "null"
                ],
                "minimum": 0,
                "maximum": 1
              },
              "kev": {
                "type": "boolean"
              },
              "exposure": {
                "type": "object",
                "required": [
                  "internet_facing",
                  "authenticated_required",
                  "privilege_boundary",
                  "reachable"
                ],
                "properties": {
                  "internet_facing": {
                    "type": "boolean"
                  },
                  "authenticated_required": {
                    "type": "boolean"
                  },
                  "privilege_boundary": {
                    "type": "string",
                    "enum": [
                      "none",
                      "user_to_admin",
                      "container_to_host",
                      "app_to_cloud_admin"
                    ]
                  },
                  "reachable": {
                    "type": "boolean"
                  }
                },
                "additionalProperties": false
              },
              "references": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "kind",
                    "ref"
                  ],
                  "properties": {
                    "kind": {
                      "type": "string"
                    },
                    "ref": {
                      "type": "string"
                    },
                    "sha256": {
                      "type": [
                        "string",
                        "null"
                      ]
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          },
          "techniques": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "technique_id",
                "technique_name",
                "tactic",
                "confidence",
                "rationale"
              ],
              "properties": {
                "technique_id": {
                  "type": "string"
                },
                "technique_name": {
                  "type": "string"
                },
                "tactic": {
                  "type": "string"
                },
                "confidence": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "rationale": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "control_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "control_id",
          "title",
          "status",
          "confidence",
          "evidence"
        ],
        "properties": {
          "control_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "partial",
              "fail",
              "not_applicable"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "kind",
                "ref"
              ],
              "properties": {
                "kind": {
                  "type": "string"
                },
                "ref": {
                  "type": "string"
                },
                "sha256": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              },
              "additionalProperties": false
            }
          },
          "notes": {
            "type": [
              "string",
              "null"
            ]
          },
          "mitigation_links": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "recommendation_id",
          "priority",
          "title",
          "description",
          "owner"
        ],
        "properties": {
          "recommendation_id": {
            "type": "string"
          },
          "priority": {
            "type": "string",
            "enum": [
              "p0",
              "p1",
              "p2",
              "p3"
            ]
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "owner": {
            "type": "string",
            "enum": [
              "app",
              "platform",
              "secops",
              "iam",
              "network",
              "data",
              "other"
            ]
          },
          "related_controls": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "related_cves": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "related_techniques": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "methodology": {
      "type": "object"
    },
    "provenance": {
      "type": "object"
    }
  },
  "additionalProperties": false
}